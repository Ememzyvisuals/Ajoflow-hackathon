# ============================================================
# AjoFlow Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Nomba Environment ─────────────────────────────────────────
# "sandbox" → uses https://sandbox.nomba.com/v1
# "production" → uses https://api.nomba.com/v1
NOMBA_ENV=sandbox

# ── Nomba Account IDs (from hackathon welcome email) ──────────
# Main (parent) Account ID — used in accountId header
NOMBA_PARENT_ACCOUNT_ID=f666ef9b-888e-4799-85ce-acb505b28023

# Your sub-account ID — pre-created on Nomba dashboard
# Sub-accounts are created via dashboard ONLY (not API)
NOMBA_SUB_ACCOUNT_ID=67c2a394-e9dc-4e53-9750-31f7c9cf29f6

# ── Nomba TEST Credentials (Sandbox) ─────────────────────────
NOMBA_CLIENT_ID=706df6c4-b8bb-4130-88c4-d21b052f8631
NOMBA_CLIENT_SECRET=k8UobYk3APgOoxUnNL7VpuxzwTsH4LsXtydfjcHs8RH0YISBB4OMqJsaafG+U8fWETu9YZ96bNXE+DelCDuMPw==

# ── Nomba LIVE Credentials (Production) ──────────────────────
# Uncomment and use when switching NOMBA_ENV=production
# NOMBA_CLIENT_ID=e5e85b13-f560-4643-814e-c87435dbbc15
# NOMBA_CLIENT_SECRET=8/doS7Q3w77EANpk3vpgSrc05hhOiRWp3eBs01sXyZ1AmovtZUXlmrxie+xnEF2tR4q79t0lFufMD1d4JrkT8g==

# ── Nomba Webhook Secret ──────────────────────────────────────
# Confirmed from Nomba hackathon webhook registration form
NOMBA_WEBHOOK_SECRET=NombaHackathon2026

# ── Sandbox Test Cards ────────────────────────────────────────
# Standard payment:     5060 6666 6666 6666 666  (any expiry/CVV)
# Insufficient funds:   5060 6666 6666 6666 674
# Card tokenization:    5434621074252808 | PIN: 0000 | OTP: 000000
# Test bank:            Wema Bank | Account: 0000000000

# ── Groq AI (Round-Robin Failover) ────────────────────────────
GROQ_KEY_1=gsk_your_first_groq_key
GROQ_KEY_2=gsk_your_second_groq_key
GROQ_KEY_3=gsk_your_third_groq_key

# ── Resend Email ──────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=AjoFlow <noreply@ajoflow.com>

# ── App Config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AjoFlow
